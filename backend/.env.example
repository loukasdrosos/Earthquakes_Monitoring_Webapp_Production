# ==============================
# Django Settings
# ==============================

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DJANGO_TIME_ZONE=UTC


# ==============================
# Database Configuration
# ==============================

# Local development:
DATABASE_URL=sqlite:///db.sqlite3
DB_SSL_REQUIRE=False

# Production example with Neon PostgreSQL:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# DB_SSL_REQUIRE=True


# ==============================
# Data Fetch Settings
# ==============================

DATA_FETCH_URL=http://www.geophysics.geol.uoa.gr/stations/maps/seismicity.xml


# ==============================
# CORS / Frontend Settings
# ==============================

# Local React dev server examples:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Production example:
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

CSRF_TRUSTED_ORIGINS=

# Production example:
# CSRF_TRUSTED_ORIGINS=https://your-backend.onrender.com,https://your-frontend.vercel.app


# ==============================
# Cron / Update Endpoint
# ==============================

CRON_SECRET=change-me-to-a-long-random-secret